<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config — loopback-only cleartext.

  Android 9+ (targetSdk >= 28) blocks cleartext HTTP by default. The Engine
  tab loads the engine SPA from http://127.0.0.1:8000, which is loopback
  but still gets blocked under the default policy. Without this exemption
  the WebView renders a black screen with no error overlay (the cleartext
  block silently zeros the response body before onReceivedError fires).

  Scope: 127.0.0.1 + localhost ONLY. All other HTTP remains blocked. If a
  future LAN-dev mode is ever added (engine on laptop, app on phone) the
  whitelist would need to grow — for v0.1.0 the engine is co-resident on
  the device, so loopback is the only legitimate cleartext target.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
